
<header>
    <nav class="navbar">
    <a href="/" class="nav-logo">Rivals Track</a>
    
    <div class="nav-links">
        <a href="/heroes" class="<%= currentPage === 'heroes' ? 'nav-active' : '' %>">Helden</a>
        <a href="/stats" class="<%= currentPage === 'stats' ? 'nav-active' : '' %>">Statistieken</a>
        <a href="/news" class="<%= currentPage === 'news' ? 'nav-active' : '' %>">Nieuws</a>

        <% if (locals.user) { %>
            <div class="dropdown d-inline">
                <button class="btn-yellow dropdown-toggle" type="button" id="userMenu" data-bs-toggle="dropdown">
                    <%= user.username %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/account/edit">Edit Account</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/logout">Log Out</a></li>
                </ul>
            </div>
        <% } else { %>
            <a href="/login" class="btn-yellow login-link">Log In</a>
        <% } %>
    </div>
</nav>
</header>