<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rivals Track - Auth</title>
    <%- include('partials/bootstrap') %>
    <link rel="stylesheet" href="./css/login.css" />
  </head>
  <body>
    <nav class="navbar">
      <a href="/" class="nav-logo">Rivals Track</a>
    </nav>

    <main class="login-container">
      <form class="login-card" action="/auth" method="POST">
        <h2 id="form-title">Login</h2>
        
        <input type="hidden" name="mode" id="auth-mode" value="login">

        <div class="input-group" id="username-group" style="display: none;">
          <label for="username">Username:</label>
          <input type="text" id="username" name="username" />
        </div>

        <div class="input-group">
          <label for="email">Email:</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="input-group">
          <label for="password">Password:</label>
          <input type="password" id="password" name="password" required />
        </div>

        <button type="submit" class="btn login-button" id="submit-btn">Log in</button>
        
        <% if (locals.error) { %>
          <p style="color:red;"><%= error %></p>
        <% } %>

        <p class="mt-3">
          <a href="#" id="toggle-link" onclick="toggleMode()">Don't have an account? Register here.</a>
        </p>
      </form>
    </main>

    <script>
      function toggleMode() {
        const modeInput = document.getElementById('auth-mode');
        const userGroup = document.getElementById('username-group');
        const title = document.getElementById('form-title');
        const btn = document.getElementById('submit-btn');
        const link = document.getElementById('toggle-link');

        if (modeInput.value === 'login') {
          modeInput.value = 'register';
          title.innerText = 'Register';
          btn.innerText = 'Create Account';
          link.innerText = 'Already have an account? Log in.';
          userGroup.style.display = 'block';
        } else {
          modeInput.value = 'login';
          title.innerText = 'Login';
          btn.innerText = 'Log in';
          link.innerText = "Don't have an account? Register here.";
          userGroup.style.display = 'none';
        }
      }
    </script>
  </body>
</html>